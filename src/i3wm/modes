# vi:ft=i3config

# Use pactl to adjust volume in PulseAudio.
mode "adjust volume" {
  set $refresh_i3status killall -SIGUSR1 i3status

  set $volume  pactl set-sink-volume @DEFAULT_SINK@
  set $mute    pactl set-sink-mute   @DEFAULT_SINK@   toggle
  set $micMute pactl set-source-mute @DEFAULT_SOURCE@ toggle

  # adjustment
  bindsym $up         exec --no-startup-id $volume +2% && $refresh_i3status
  bindsym $down       exec --no-startup-id $volume -2% && $refresh_i3status
  
  # faster volumn adjustment
  bindsym Shift+$up   exec --no-startup-id $volume +4% && $refresh_i3status
  bindsym Shift+$down exec --no-startup-id $volume -4% && $refresh_i3status

  # mute
  bindsym m mode "default" exec --no-startup-id $mute && $refresh_i3status

  # toggle mode
  bindsym $mod+v mode "default"

  # escape mode
  bindsym Return           mode "default"
  bindsym ctrl+m           mode "default"
  bindsym Escape           mode "default"
  bindsym q                mode "default"
  bindsym ctrl+c           mode "default"
  bindsym ctrl+bracketleft mode "default"
}

# move window to a workspace and toggle focus
mode "move window" {
  bindsym  1 mode "default" $move $ws1  $switch $ws1
  bindsym  2 mode "default" $move $ws2  $switch $ws2
  bindsym  3 mode "default" $move $ws3  $switch $ws3
  bindsym  4 mode "default" $move $ws4  $switch $ws4
  bindsym  5 mode "default" $move $ws5  $switch $ws5
  bindsym  6 mode "default" $move $ws6  $switch $ws6
  bindsym  7 mode "default" $move $ws7  $switch $ws7
  bindsym  8 mode "default" $move $ws8  $switch $ws8
  bindsym  9 mode "default" $move $ws9  $switch $ws9
  bindsym 10 mode "default" $move $ws10 $switch $ws10

  # toggle mode
  bindsym $mod+m mode "default"

  # escape mode
  bindsym Return           mode "default"
  bindsym ctrl+m           mode "default"
  bindsym Escape           mode "default"
  bindsym q                mode "default"
  bindsym ctrl+c           mode "default"
  bindsym ctrl+bracketleft mode "default"
}

# split window orientation
mode "orientation" {

  bindsym v split v mode "default"
  bindsym h split h mode "default"
  bindsym f split h mode "default"

  # toggle mode
  bindsym $mod+o mode "default"


  # escape mode
  bindsym ctrl+m           mode "default"
  bindsym Escape           mode "default"
  bindsym q                mode "default"
  bindsym ctrl+c           mode "default"
  bindsym ctrl+bracketleft mode "default"
}


# scrolling 
  # TODO: add scroll to bottom/top
mode "scroll" {
  bindsym j exec --no-startup-id xdotool click 5
  bindsym k exec --no-startup-id xdotool click 4

  bindsym $mod+Tab mode "default"; workspace back_and_forth

  # toggle mode
  bindsym $mod+s mode "default"

  # escape mode
  bindsym Return           mode "default"
  bindsym ctrl+m           mode "default"
  bindsym Escape           mode "default"
  bindsym q                mode "default"
  bindsym ctrl+c           mode "default"
  bindsym ctrl+bracketleft mode "default"
}


# resize window (you can also use the mouse for that)
mode "resize" {

  bindsym $mod+space mode "resize > float"

  # hjkl
  bindsym $left  resize shrink width 2 px or 2 ppt
  bindsym $down  resize shrink height 2 px or 2 ppt
  bindsym $up    resize grow height 2 px or 2 ppt
  bindsym $right resize grow width 2 px or 2 ppt
  # arrow keys
  bindsym Left  resize shrink width 10 px or 10 ppt
  bindsym Down  resize grow height 10 px or 10 ppt
  bindsym Up    resize shrink height 10 px or 10 ppt
  bindsym Right resize grow width 10 px or 10 ppt

  # quit mode
  bindsym $mod+r mode "default"

  # escape mode
  bindsym Return           mode "default"
  bindsym ctrl+m           mode "default"
  bindsym Escape           mode "default"
  bindsym q                mode "default"
  bindsym ctrl+c           mode "default"
  bindsym ctrl+bracketleft mode "default"
}

# resize floats
mode "resize > float" {
  # cycle through predefined sizes
  bindsym Shift+k exec --no-startup-id "~/Projects/dotfiles/src/i3wm/bin/window_resizer.bash 'up'"
  bindsym Shift+j exec --no-startup-id "~/Projects/dotfiles/src/i3wm/bin/window_resizer.bash 'down'"

  # escape mode
  bindsym Return           mode "default"
  bindsym ctrl+m           mode "default"
  bindsym Escape           mode "default"
  bindsym q                mode "default"
  bindsym ctrl+c           mode "default"
  bindsym ctrl+bracketleft mode "default"
}

# toggle gaps
mode "toggle gaps" {
  bindsym $up         gaps inner current set 10; gaps outer current set 50
  bindsym $down       gaps inner current set 5; gaps outer current set 0
  bindsym Shift+$up   gaps inner current set 10; gaps outer current set 40
  bindsym Shift+$down gaps inner current set 0; gaps outer current set 0

  # toggle mode
  bindsym $mod+g mode "default" 

  # escape mode
  bindsym Return           mode "default"
  bindsym ctrl+m           mode "default"
  bindsym Escape           mode "default"
  bindsym q                mode "default"
  bindsym ctrl+c           mode "default"
  bindsym ctrl+bracketleft mode "default"
}
