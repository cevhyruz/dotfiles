# vi:ft=i3config
# i3 config file (v4.22)
# see https://i3wm.org/docs/userguide.html for a complete reference!


set $i3wm_home ~/Projects/dotfiles/src/i3wm

# start polybar
exec_always --no-startup-id ~/Projects/dotfiles/src/i3wm/bin/launch_polybar.bash


# xss-lock grabs a logind suspend inhibit lock and will use i3lock to lock the
# screen before suspend. Use loginctl lock-session to lock your screen.
exec --no-startup-id xss-lock --transfer-sleep-lock -- i3lock --nofork

# NetworkManager is the most popular way to manage wireless networks on Linux,
# and nm-applet is a desktop environment-independent system tray GUI for it.
exec --no-startup-id nm-applet

# wallpaper
exec --no-startup-id feh --bg-scale ~/Pictures/mountain.jpg

font -misc-fixed-medium-r-normal--13-120-75-75-C-70-iso10646-1
font pango:JetBrainsMono 11
font pango:DejaVu Sans Mono, Terminus Bold Semi-Condensed 12
font pango:Terminus 12px

# set a solid color background instead of an image
# exec_always --no-startup-id xsetroot -solid "#FFF"

# Note this will disable --bg-color in feh
exec --no-startup-id mons -s
exec --no-startup-id picom -b


# make sure figma is always focus, in preparation for scroll
for_window [class="figma"] focus


# Windows config for my Asus Monitor with cracked bottom part
#
#   $: xdpyinfo | grep dimension
#   dimensions:    1366x768 pixels (361x203 millimeters)
#
# border indicator
for_window [class="^.*"] border pixel 5

# gaps (with 1 polybar, and a damaged bottom screen)
# gaps top 35

# gaps inner 10

gaps inner 10
gaps outer 10

gaps bottom 80

# map the corners, considers the damaged part of my monitor.
# this will be used for better tiling later.
set $XStart 0px
set $XEnd   684px
set $YStart 35px
set $YEnd   368px

# predetermined window sizes
set $window-sm resize set width 

# left boundary 1364px -  2 general window border
# bottom boundary 697px - including the 35px from polybar
for_window [class="^float"] floating enable, border pixel 5
for_window [class="^float"] resize set width 682px height 339px
#
# Float Sizes
for_window [class="^float--xxs"]  resize set width 350px height 140px
for_window [class="^float--xs"]   resize set width 450px height 220px
for_window [class="^float--sm"]   resize set width 682px height 339px
for_window [class="^float--md"]   resize set width 910px height 480px
for_window [class="^float--lg"]   resize set width 1160px height 570px
for_window [class="^float--xl"]   resize set width 1326px height 630px
for_window [class="^float--full"] resize set width 1364px height 662px
#
# Float Position (x, y)
for_window [class="float--xxs--center"]   move position 510px 303px
for_window [class="float--xs--center"]   move position 458px 260px
for_window [class="float--sm--center"]   move position 341px 201px
for_window [class="float--md--center"]   move position 227px 125px
for_window [class="float--lg--center"]   move position 103px 84px
for_window [class="float--xl--center"]   move position 21px 55px
for_window [class="float--full--center"]   move position 0px 35px
#
# snap

for_window [class="^float--topleft"]  move position 0px 35px
for_window [class="^float--topright"] move position 684px 35px
for_window [class="^float--botleft"]  move position 0px 368px
for_window [class="^float--botright"]  move position 684px 368px
# #
# #
# for_window [class="^float--bottom"] move position 0px 298px
# for_window [class="float--bottom--sm"] resize set 225px 400px
# for_window [class="float--bottom--md"] resize set 625px 400px

# size: small, medium, large
# position: topleft, topcenter, topright, center, bottomleft, bottomcenter, bottomright

bindsym $mod+i move scratchpad
bindsym $mod+shift+i scratchpad show


set $mod Mod1

# aliases
set $move      move container to workspace number
set $switch    workspace number

set $term      --no-startup-id gnome-terminal

# floating window sizes (width X height)
set $float_small  --geometry 50x20
set $float_normal --geometry 90x40
set $float_large  --geometry 90x40

# floating gnome-terminal
set $floatterm    --no-startup-id gnome-terminal --title floating_term

bindsym $mod+a focus parent

# focus, movement and resize directions
set $left  h
set $down  j
set $up    k
set $right l

set $ws1  "1"
set $ws2  "2"
set $ws3  "3"
set $ws4  "4"
set $ws5  "5"
set $ws6  "6"
set $ws7  "7"
set $ws8  "8"
set $ws9  "9"
set $ws10 "10"

#include $i3wm_homei3bar
include $i3wm_home/keybindings
include $i3wm_home/modes
