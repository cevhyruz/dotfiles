# vim: set ft=dosini :

[bar/example]

width = 100%
height = 20pt
radius = 0
dpi = 96

background = ${colors.background}
foreground = ${colors.foreground}

line-size = 1pt

border-size = 0pt
border-color = #285577

padding-left = 0
padding-right = 1

module-margin = 2

separator = |
separator-foreground = ${colors.disabled}

font-0 = "JetBrainsMono Nerd Font:size=10;2"
font-1 = "FontAwesome:size=9;2"
font-2 = siji:pixelsize=11;1

# [modules]
modules-left = i3 cpu memory scratchpad
modules-center = date orientation
modules-right =  pulseaudio wlan battery date

cursor-click = pointer
cursor-scroll = ns-resize

enable-ipc = true

;tray-position = right

; wm-restack = generic
; wm-restack = bspwm
# wm-restack = i3

; override-redirect = true
# The distance from the top of the screen
; offset-y = 0

# The distance from the sides (optional, for a floating look)

# Position the bar at the top
# bottom = false
